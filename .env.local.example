# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# Supabase / Prisma
# Use the Supabase "connection pooling" string for DATABASE_URL (pgbouncer, port 6543)
# and the "direct connection" string for DIRECT_URL (port 5432) — Prisma needs both
# for migrations to work correctly against Supabase.
DATABASE_URL=
DIRECT_URL=